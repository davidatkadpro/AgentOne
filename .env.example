PORT=3737
DB_PATH=./data/agentone.db
BASE_PROMPT_PATH=./prompts/base.md
MODEL_PROFILES_DIR=./profiles/models
LMSTUDIO_BASE_URL=http://localhost:1234/v1
DEFAULT_MODEL_PROFILE=local-fast
COMPRESSOR_MODEL_PROFILE=local-compressor

# Storage root holds wiki/, projects/, drafts/. Point at a OneDrive-synced
# folder in production; a local folder for dev/offline. Same code path.
#
# Windows path note: prefer single quotes (literal) or forward slashes.
# Double quotes process escape sequences (\U etc.) and will silently mangle
# backslash paths.
#
#   STORAGE_ROOT='C:\Users\You\OneDrive\AgentOne'
#   STORAGE_ROOT="C:/Users/You/OneDrive/AgentOne"
STORAGE_ROOT=./storage
WIKI_PREFIX=wiki

# Skills & agent profile (M3+)
SKILLS_DIR=./skills
AGENT_PROFILES_DIR=./profiles/agents
AGENT_PROFILE=_base

LOG_EVENTS=0
