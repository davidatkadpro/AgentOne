PORT=3737

# Bind address. 127.0.0.1 (default) = localhost only. 0.0.0.0 = listen on
# every interface, reachable from other machines on the LAN. There is NO
# auth on the REST/WS endpoints — only expose on a trusted network.
HOST=127.0.0.1

DB_PATH=./data/agentone.db
BASE_PROMPT_PATH=./prompts/base.md
MODEL_PROFILES_DIR=./profiles/models
LMSTUDIO_BASE_URL=http://localhost:1234/v1
DEFAULT_MODEL_PROFILE=local-fast
COMPRESSOR_MODEL_PROFILE=local-compressor

# Storage root holds wiki/, projects/, drafts/. Point at a OneDrive-synced
# folder in production; a local folder for dev/offline. Same code path.
#
# Windows path note: prefer single quotes (literal) or forward slashes.
# Double quotes process escape sequences (\U etc.) and will silently mangle
# backslash paths.
#
#   STORAGE_ROOT='C:\Users\You\OneDrive\AgentOne'
#   STORAGE_ROOT="C:/Users/You/OneDrive/AgentOne"
STORAGE_ROOT=./storage
WIKI_PREFIX=wiki

# Skills & agent profile (M3+)
SKILLS_DIR=./skills
AGENT_PROFILES_DIR=./profiles/agents
AGENT_PROFILE=_base

LOG_EVENTS=0

# ── Email source ─────────────────────────────────────────────────────────
# Pick the connector explicitly, or leave EMAIL_SOURCE unset to infer it
# (graph if M365 creds are set, else maildir if EMAIL_MAILDIR_PATH is set).
#
# Local .eml folder (dev / offline):
#   EMAIL_SOURCE=maildir
#   EMAIL_MAILDIR_PATH=./tmp/maildir
#
# Real Microsoft 365 inbox (read-only OAuth) — see README "Microsoft 365
# email setup" for the Entra app registration steps:
#   EMAIL_SOURCE=graph
#   M365_CLIENT_ID=...
#   M365_CLIENT_SECRET=...
#   M365_TENANT_ID=common
#   EMAIL_POLL_INTERVAL_MIN=5
#   # Non-Windows hosts need a vault key (Windows uses DPAPI automatically):
#   QBO_TOKEN_KEY=change-me
